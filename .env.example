# ACP (Virtuals SDK)
# Get these from https://app.virtuals.io/acp/join after registering your agent
WHITELISTED_WALLET_PRIVATE_KEY=  # 0x-prefixed, dev wallet whitelisted during ACP registration
SELLER_AGENT_WALLET_ADDRESS=     # Smart wallet address created during ACP registration
SELLER_ENTITY_ID=                # Session entity ID from ACP registration

# Limitless
PRIVATE_KEY=                     # 0x-prefixed, Limitless trading wallet (Base chain, needs USDC + small ETH for gas)
LIMITLESS_API_KEY=               # From Limitless Exchange
LIMITLESS_API_URL=https://api.limitless.exchange

# Operational
LOG_LEVEL=info
DRY_RUN=false
